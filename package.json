{
  "name": "patchpilot",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first coding agent TUI powered by Ollama.",
  "type": "module",
  "bin": {
    "patchpilot": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
