# Provider options: ollama, gemini, codex.
# codex uses your Codex CLI ChatGPT login. Run: codex login
PATCHPILOT_PROVIDER=codex
PATCHPILOT_MODEL=gpt-5.4

# Only needed for the Gemini provider.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional tuning shared by Ollama and Gemini.
PATCHPILOT_NUM_PREDICT=1024
PATCHPILOT_TEMPERATURE=0.1
